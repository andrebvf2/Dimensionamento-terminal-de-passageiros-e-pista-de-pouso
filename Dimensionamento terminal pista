# DIMENSIONAMENTO PRELIMINAR 
# LEITOR DE INPUT + PROJECAO DE POPULACAO



def ler_arquivo_input(caminho_arquivo):

    dados = {}

    with open(caminho_arquivo, "r", encoding="utf-8") as arquivo:
        linhas = arquivo.readlines()

    i = 0
    while i < len(linhas):
        linha = linhas[i].strip()

        # POPULACAO 
        if linha == "POPULACAO":
            dados["POPULACAO"] = ler_populacao(linhas, i + 1)

        # ALTITUDE 
        elif linha == "ALTITUDE":
            dados["ALTITUDE"] = ler_valor_simples(linhas, i + 1)

        # TEMPERATURA 
        elif linha == "TEMPERATURA":
            dados["TEMPERATURA"] = ler_valor_simples(linhas, i + 1)

        # DECLIVIDADE
        elif linha == "DECLIVIDADE":
            dados["DECLIVIDADE"] = ler_valor_simples(linhas, i + 1)

        i += 1

    return dados


# POPULACAO
def ler_populacao(linhas, indice_inicial):

    dados_pop = {}
    i = indice_inicial

    while i < len(linhas):
        linha = linhas[i].strip()

        if linha == "":
            break

        if linha.startswith("OPCAO"):
            dados_pop["opcao"] = int(linha.split()[1])

        elif linha.startswith("ANOS"):
            vetor = linha.split("{")[1].split("}")[0]
            anos = [int(x.strip()) for x in vetor.split(",")]
            dados_pop["anos"] = anos
            break

        elif linha.startswith("INTERVALO"):
            dados_pop["intervalo"] = int(linha.split()[1])

        elif linha.startswith("NUM_INTERVALOS"):
            dados_pop["num_intervalos"] = int(linha.split()[1])
            break

        i += 1

    return gerar_vetor_anos(dados_pop)


# VALOR SIMPLES
def ler_valor_simples(linhas, indice_inicial):

    linha = linhas[indice_inicial].strip()
    valor = float(linha.split()[1])
    return valor


# GERAR ANOS
def gerar_vetor_anos(dados_pop):

    if dados_pop["opcao"] == 1:
        return dados_pop["anos"]

    elif dados_pop["opcao"] == 2:
        intervalo = dados_pop["intervalo"]
        n = dados_pop["num_intervalos"]

        return [intervalo * i for i in range(1, n + 1)]


# MAIN
if __name__ == "__main__":

    dados = ler_arquivo_input("input.txt")

    print("\n==== DADOS LIDOS DO INPUT ====")
    print("Anos:", dados["POPULACAO"])
    print("Altitude:", dados["ALTITUDE"])
    print("Temperatura:", dados["TEMPERATURA"])
    print("Declividade:", dados["DECLIVIDADE"])

    print("\n==== LOOP DE CALCULO ====")

    for ano in dados["POPULACAO"]:
        print(f"Calculando para {ano} anos...")

